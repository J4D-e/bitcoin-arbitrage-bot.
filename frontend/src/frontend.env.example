# ═══════════════════════════════════════════════════════
# Bitcoin Arbitrage Bot — Frontend
# Copia este archivo como .env y ajusta las URLs
# NUNCA subas .env a GitHub
# Todas las variables deben empezar con VITE_ para ser visibles en React
# ═══════════════════════════════════════════════════════

# URL del backend FastAPI
# Desarrollo local:
VITE_API_URL=http://localhost:8000
# Producción (descomenta y ajusta):
# VITE_API_URL=https://api.tudominio.com

# URL del WebSocket del backend
# Desarrollo local:
VITE_WS_URL=ws://localhost:8000/ws
# Producción con HTTPS (descomenta y ajusta):
# VITE_WS_URL=wss://api.tudominio.com/ws
