# ═══════════════════════════════════════════════════════
# Bitcoin Arbitrage Bot — Backend
# Copia este archivo como .env y completa tus valores
# NUNCA subas .env a GitHub
# ═══════════════════════════════════════════════════════

# ── Servidor ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── Trading ─────────────────────────────────────────────
MIN_SPREAD_PCT=0.15
TRADE_AMOUNT_USDT=100.0
SLIPPAGE_PCT=0.05
MAX_OPEN_TRADES=3

# ── Circuit Breaker ──────────────────────────────────────
CIRCUIT_BREAKER_MAX_LOSS_USD=50.0
CIRCUIT_BREAKER_WINDOW_SEC=300

# ── Binance ──────────────────────────────────────────────
# Solo necesario para órdenes reales (no para precios en tiempo real)
# https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=tu_api_key_aqui
BINANCE_API_SECRET=tu_api_secret_aqui

# ── Kraken ───────────────────────────────────────────────
# Solo necesario para órdenes reales
# https://www.kraken.com/u/security/api
KRAKEN_API_KEY=tu_api_key_aqui
KRAKEN_API_SECRET=tu_api_secret_aqui

# ── Coinbase ─────────────────────────────────────────────
# Solo necesario para órdenes reales
# https://www.coinbase.com/settings/api
COINBASE_API_KEY=tu_api_key_aqui
COINBASE_API_SECRET=tu_api_secret_aqui
